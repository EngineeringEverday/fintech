# Copy to .env to customise. All variables are OPTIONAL — SettleIQ works
# fully offline with deterministic mock responses by default.

# Set to "true" to attempt routing the formatter through a real LLM.
# (The default code path returns deterministic structured responses; a real
# LLM hookup is left as an extension point — keys would be read from below.)
USE_REAL_LLM=false

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
